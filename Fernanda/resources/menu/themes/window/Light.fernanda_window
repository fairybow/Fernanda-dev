/* --- Status bar ------------------- */

@statusbar_background; = #f8f8ff;

@toolbutton_background; = transparent;
@toolbutton_color; = #28282a;

@toolbutton_hover_background; = #dcdcdc;
@toolbutton_hover_color; = #007fff;

@toolbutton_pressed_background; = #dcdcdc;
@toolbutton_pressed_color; = #28282a;
