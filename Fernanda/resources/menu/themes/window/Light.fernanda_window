/*

Light/dark palette:

#fff = 0
#f4f4f4 = 1
#eaeaea = 2
---
#e2e2e2 = 3.0
#d9d9d9 = 3.1
---
#c8c8c8 = 4
#848484 = 5
#545454 = 6
---
#444 = 7.0
#3c3c3c = 7.1
---
#333 = 8
#1f1f1f = 9
#000 = 10
---
#007fff = 11 (Azure)
#e52b50 = 12 (Amaranth)

*/



/* ---------------------------------- */

@mainwindow_background; = #f4f4f4;
@meter_color; = #545454;



/* --- Menu bar --------------------- */

@menubar_background; = #f4f4f4;
@menubar_color; = #545454;

@menubar_itemselected_background; = #c8c8c8;
@menubar_itemselected_color; = #007fff;

@menubar_itempressed_background; = #c8c8c8;
@menubar_itempressed_color; = #007fff;



/* --- Tab bar ---------------------- */

@tabbar_background; = #eaeaea;

@tabbar_tab_background; = #e2e2e2;
@tabbar_tab_color; = #545454;

@tabbar_tabhover_background; = #d9d9d9;
@tabbar_tabhover_color; = #007fff;

@tabbar_tabselected_background; = #f4f4f4;

@tabbutton_background; = transparent;
@tabbutton_color; = #545454;

@tabbutton_hover_background; = #c8c8c8;
@tabbutton_hover_color; = #007fff;

@tabbutton_pressed_background; = #c8c8c8;
@tabbutton_pressed_color; = #545454;

/* ellipse needs to be scaled to half and display hover color on tab hover */
