/* --- Status bar ------------------- */

@statusbar_background; = #f4f4f4;

@toolbutton_background; = transparent;
@toolbutton_color; = #545454;

@toolbutton_hover_background; = #c8c8c8;
@toolbutton_hover_color; = #007fff;

@toolbutton_pressed_background; = #c8c8c8;
@toolbutton_pressed_color; = #545454;
