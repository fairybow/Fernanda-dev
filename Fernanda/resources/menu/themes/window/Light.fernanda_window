/*

Light theme palette (wip):

#f8f8ff = Ghost white
#e52b50 = Amaranth
#007fff = Azure
#28282a = Very dark (mostly black) blue
#f2f3f4 = Munsell, Anti-flash white
#dcdcdc = Gainsboro
#cfcfc4 = Pastel gray
#e5e4e2 = Platinum

*/



/* ---------------------------------- */

@mainwindow_background; = #f8f8ff;
@meter_color; = #28282a;



/* --- Menu bar --------------------- */

@menubar_background; = #f8f8ff;
@menubar_color; = #28282a;

@menubar_itemselected_background; = #dcdcdc;
@menubar_itemselected_color; = #007fff;

@menubar_itempressed_background; = #dcdcdc;
@menubar_itempressed_color; = #007fff;



/* --- Tab bar ---------------------- */

@tabbar_background; = #e5e4e2;

@tabbar_tab_background; = #f2f3f4;
@tabbar_tab_color; = #28282a;

@tabbar_tabhover_background; = #dcdcdc;
@tabbar_tabhover_color; = #007fff;

@tabbar_tabselected_background; = #f8f8ff;

@tabbutton_background; = transparent;
@tabbutton_color; = #28282a;

@tabbutton_hover_background; = #dcdcdc;
@tabbutton_hover_color; = #007fff;

@tabbutton_pressed_background; = #dcdcdc;
@tabbutton_pressed_color; = #28282a;

/* ellipse needs to be scaled to half and display hover color on tab hover */
